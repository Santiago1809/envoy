# Sample .env file for testing parser

# Basic key-value pair
DATABASE_URL=postgres://localhost:5432/db

# Single-quoted value (literal)
SINGLE_QUOTED='hello world'

# Double-quoted value (with escape sequences)
DOUBLE_QUOTED="hello\nworld"

# Inline comment
INLINE_COMMENT=value # this is a comment

# Variable expansion
DB_HOST=localhost
DB_PORT=5432
EXPANDED_URL=postgres://${DB_HOST}:${DB_PORT}/db

# Multiline value with double quotes
PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
MIIEpAIBAAKCAQEA0Z3...
-----END RSA PRIVATE KEY-----"

# Empty value
EMPTY_VALUE=

# Value with equals sign
EQUALS_TEST=value=with=equals

# Value with hash (not a comment) in double quotes
HASH_IN_QUOTES="value#notcomment"

# Trailing spaces should be trimmed
TRAILING_SPACE=value   

# Backtick quoted value (shell-like)
BACKTICK_QUOTED=`command output`

# Key with underscore and numbers
API_KEY_123=secret123

# Boolean-like values
DEBUG=true
PRODUCTION=false

# Number values
MAX_CONNECTIONS=100

# Value with colon
COLON_TEST=value:colon
